{
  "name": "spritebot",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "engines": {
    "node": "22.22.0"
  },
  "scripts": {
    "copy-sql": "cp -R src/db/tables dist/db/tables",
    "lint": "npm run lint:prettier && npm run lint:eslint",
    "clean": "rimraf dist",
    "build": "npm run clean && tsc && npm run copy-sql",
    "start": "node dist/index.js",
    "start:dev": "ts-node src/index.ts",
    "test": "jest --coverage=false",
    "test:unit": "jest tests/unit --coverage=false",
    "test:integration": "jest tests/integration --coverage=false",
    "test:e2e": "jest tests/e2e --runInBand --coverage=false",
    "lint:eslint": "eslint --ext .ts,.js src --format=stylish",
    "lint:prettier": "prettier --check .",
    "precommit": "npm run lint && npm test -- --runInBand",
    "prepare": "husky"
  },
  "author": "unprofessional",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/unprofessional/spritebot.git"
  },
  "bugs": {
    "url": "https://github.com/unprofessional/spritebot/issues"
  },
  "homepage": "https://github.com/unprofessional/spritebot#readme",
  "dependencies": {
    "discord.js": "^14.21.0",
    "dotenv": "^17.2.0",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.3.16",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.1.0",
    "@types/pg": "^8.15.4",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.31.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^51.4.1",
    "husky": "^9.1.7",
    "jest": "^30.0.5",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
