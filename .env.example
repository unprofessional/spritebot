# if using k8s, this is set by using kubectl secret
DISCORD_BOT_TOKEN="xxxxx"

### Commands
DISCORD_CLIENT_ID="xxxxx"
DEV_GUILD_ID="xxxxx"
OPS_GUILD_ID="xxxxx"
OWNER_DISCORD_ID="xxxxx"

### PostgreSQL
PG_HOST="localhost"
PG_PORT="5432"
PG_USER="postgres"
PG_PASS="xxxxx"
PG_DB="spritebot"

# Optional fallback lifecycle announcement channel.
# Prefer /bot-announcements set inside each server.
# LIFECYCLE_NOTIFY_GUILD_ID=
# LIFECYCLE_NOTIFY_CHANNEL_ID=

# Voice transcription
# TRANSCRIPTION_SERVICE_URL="http://192.168.7.73:9700/inference"
# TRANSCRIPTION_SILENCE_MS=700
# TRANSCRIPTION_MAX_SEGMENT_MS=30000
# TRANSCRIPTION_MIN_SEGMENT_MS=600
# TRANSCRIPTION_VAD_THRESHOLD=0.012

# Thread Bump Feature
# BUMP_BUFFER_MINUTES=
# BUMP_BUFFER_MINUTES=
# BUMP_MIN_MINUTES=
# BUMP_ARCHIVE_AWARE_DEFAULT=
