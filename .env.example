OWNER_DISCORD_ID="xxxxx"

### PostgreSQL
PG_HOST="localhost"
PG_PORT="5432"
PG_USER="postgres"
PG_PASS="xxxxx"
PG_DB="spritebot"

# Optional fallback lifecycle announcement channel.
# Prefer /bot-announcements set inside each server.
# LIFECYCLE_NOTIFY_GUILD_ID=
# LIFECYCLE_NOTIFY_CHANNEL_ID=

# Runtime lease / blue-green deployment controls
# SPRITEBOT_INSTANCE_MODE=active
# SPRITEBOT_INSTANCE_ID=
# SPRITEBOT_LEASE_TTL_MS=30000
# SPRITEBOT_LEASE_HEARTBEAT_MS=10000
# SPRITEBOT_STANDBY_POLL_MS=5000

